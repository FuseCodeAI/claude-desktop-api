{
  "name": "desktop-syner",
  "version": "1.0.0",
  "description": "Claude Desktop config syncer",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.1"
  },
  "build": {
    "appId": "com.claude.desktop-syner",
    "mac": {
      "target": "dmg"
    }
  }
}
